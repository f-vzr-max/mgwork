# .env.example — AsanaoConnect / mgwork
#
# PLACEHOLDER VALUES ONLY. Never commit real secrets.
# Copy to .env.local and fill in real values before running locally.
#
# Groups:
#   REQUIRED — deploy fails or auth/DB breaks without these
#   WARN     — feature degrades gracefully; silence expected in dev
#   OPTIONAL — Vercel-injected, observability, or future use; safe to omit locally
#
# Sources: lib/config.ts getters + prisma/schema.prisma + lib/csrf.ts

# ──────────────────────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────────────────────

# Supabase project URL. Dashboard → Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Supabase anon/public key. Dashboard → Project Settings → API → anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder

# Supabase service-role key. Dashboard → Project Settings → API → service_role key.
# SERVER-ONLY — never expose client-side; only read via lib/supabase.ts.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder

# Prisma primary connection (pooled via PgBouncer / Supabase connection pooler).
# Supabase → Connect → ORMs → Connection string (transaction mode, port 6543).
DATABASE_URL=postgresql://postgres.xxxxxxxxxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Prisma direct connection (used for migrations; bypasses PgBouncer).
# Supabase → Connect → ORMs → Connection string (session mode, port 5432).
DIRECT_URL=postgresql://postgres.xxxxxxxxxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Clerk secret key. Clerk dashboard → API Keys → Secret key (sk_live_…).
CLERK_SECRET_KEY=sk_test_placeholder

# Clerk webhook signing secret. Clerk dashboard → Webhooks → endpoint → Signing Secret (whsec_…).
CLERK_WEBHOOK_SECRET=whsec_placeholder

# Random secret used to authenticate Vercel Cron invocations (Authorization: Bearer).
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_with_random_32_hex_chars

# Resend API key. resend.com → API Keys → Create API Key.
RESEND_API_KEY=re_placeholder

# Verified sender address in Resend (must match a verified domain).
RESEND_FROM_EMAIL=AsanaoConnect <noreply@example.com>

# Canonical public URL of the app (no trailing slash). Used for CSRF origin
# checks and absolute URL construction. Set to the Vercel production URL in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# WARN — feature degrades gracefully when absent
# ──────────────────────────────────────────────────────────────

# Anthropic API key. console.anthropic.com → API Keys.
# When absent, AI doc-analysis returns { error: "no-key" } (no-op).
ANTHROPIC_API_KEY=sk-ant-placeholder

# Meta / WhatsApp Business credentials. Meta for Developers → App Dashboard.
# All Meta/WhatsApp vars: absence puts channel adapters in stub mode (no sends).
META_APP_ID=123456789012345
META_APP_SECRET=placeholder_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=placeholder_webhook_verify_token
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAplaceholder
META_PAGE_ACCESS_TOKEN=EAAplaceholder_page
META_PAGE_ID=123456789012345
WHATSAPP_BUSINESS_NUMBER=+1234567890

# Feature flag for channel-related UI (true / false). Optional; defaults to off.
NEXT_PUBLIC_CHANNELS_ENABLED=false

# Upstash Redis — for future distributed rate limiting (currently in-memory).
# Upstash console → database → REST API.
UPSTASH_REDIS_REST_URL=https://placeholder.upstash.io
UPSTASH_REDIS_REST_TOKEN=placeholder_upstash_token

# ──────────────────────────────────────────────────────────────
# OPTIONAL — Vercel-injected, observability, or build-time only
# ──────────────────────────────────────────────────────────────

# Automatically set by Vercel; do not set manually in production.
# Used by lib/csrf.ts for CSRF origin validation on preview deploys.
VERCEL_URL=mgwork-abc123.vercel.app
VERCEL_BRANCH_URL=mgwork-git-main-team.vercel.app
VERCEL_PROJECT_PRODUCTION_URL=mgwork-seven.vercel.app
VERCEL_ENV=development

# Non-public server-side URL alias (used in lib/csrf.ts origin resolution).
APP_URL=http://localhost:3000

# NODE_ENV is set by Next.js/the runtime; do not override in .env files.
NODE_ENV=development

# Sentry — observability. sentry.io → Settings → Projects → select project.
# Absence triggers a no-op Sentry init; local dev works fine without these.
SENTRY_DSN=https://placeholder@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN is build-time only (uploads source maps via withSentryConfig in CI).
# sentry.io → Settings → Auth Tokens → Create Token (scope: project:releases + org:read).
SENTRY_AUTH_TOKEN=sntrys_placeholder
SENTRY_ORG=placeholder-org
SENTRY_PROJECT=placeholder-project
