# MRU self-hosted Supabase — env to set. Two parts:
#   (A) values to put in supabase/docker/.env on the box
#   (B) the diff to set in Vercel (Production) so the app points at the box
# Placeholders only. Generate every secret fresh — the default self-hosted
# Supabase keys are publicly known. Replace supabase.example.mu with your host.

# ============ (A) ON THE BOX — supabase/docker/.env ============
# Generate: openssl rand -hex 24  (passwords) / openssl rand -hex 32 (JWT secret)
POSTGRES_PASSWORD=__GENERATE__
JWT_SECRET=__GENERATE_40+_CHARS__
# ANON_KEY / SERVICE_ROLE_KEY are JWTs signed with JWT_SECRET (roles "anon" /
# "service_role", iss "supabase", long exp). Use Supabase's key generator.
ANON_KEY=__SIGNED_WITH_JWT_SECRET__
SERVICE_ROLE_KEY=__SIGNED_WITH_JWT_SECRET__
DASHBOARD_USERNAME=__SET__
DASHBOARD_PASSWORD=__GENERATE__
# Public URLs (HTTPS via Caddy -> Kong on :8000)
SITE_URL=https://supabase.example.mu
API_EXTERNAL_URL=https://supabase.example.mu
SUPABASE_PUBLIC_URL=https://supabase.example.mu
# Pooler — the tenant id becomes part of the DATABASE_URL username below.
POOLER_TENANT_ID=__SET__
POOLER_PROXY_PORT_TRANSACTION=6543

# ============ (B) ON VERCEL — Production env ============
# DATABASE_URL MUST hit the Supavisor transaction pooler with pgbouncer=true —
# Vercel serverless exhausts raw Postgres otherwise. Username includes the tenant.
DATABASE_URL=postgresql://postgres.__POOLER_TENANT_ID__:__POSTGRES_PASSWORD__@supabase.example.mu:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_URL = direct Postgres for `prisma migrate deploy` (only needs to be
# reachable from Vercel if migrations run in the build; else migrate on-box).
DIRECT_URL=postgresql://postgres:__POSTGRES_PASSWORD__@supabase.example.mu:5432/postgres?sslmode=require
NEXT_PUBLIC_SUPABASE_URL=https://supabase.example.mu
NEXT_PUBLIC_SUPABASE_ANON_KEY=__ANON_KEY__
SUPABASE_SERVICE_ROLE_KEY=__SERVICE_ROLE_KEY__
